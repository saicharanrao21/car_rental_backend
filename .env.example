# Database connection URL (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]?schema=public
# DEV-ONLY: Defaults for local user-space pg_ctl setup
DATABASE_URL="postgresql://postgres:postgrespassword123@localhost:5433/car_rental?schema=public"

# Redis connection URL
# DEV-ONLY: Defaults for local Redis setup
REDIS_URL="redis://localhost:6379"

# JWT configuration secrets & parameters
# DEV-ONLY: Replace these with strong, randomly generated keys in production
JWT_ACCESS_SECRET="dev_access_secret_key_change_me_12345!"
JWT_REFRESH_SECRET="dev_refresh_secret_key_change_me_12345!"

JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"
