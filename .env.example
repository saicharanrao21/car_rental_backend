# Database connection URL (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]?schema=public
# DEV-ONLY: Defaults for local user-space pg_ctl setup
DATABASE_URL="postgresql://postgres:postgrespassword123@localhost:5433/car_rental?schema=public"

# Redis connection URL
# DEV-ONLY: Defaults for local Redis setup
REDIS_URL="redis://localhost:6379"

# JWT configuration secrets & parameters
# DEV-ONLY: Replace these with strong, randomly generated keys in production
JWT_ACCESS_SECRET="dev_access_secret_key_change_me_12345!"
JWT_REFRESH_SECRET="dev_refresh_secret_key_change_me_12345!"

JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# Razorpay API Credentials (Test Mode)
# Get these by signing up on razorpay.com -> Settings -> API Keys (toggle to Test Mode)
RAZORPAY_KEY_ID="rzp_test_placeholderKeyId"
RAZORPAY_KEY_SECRET="placeholderKeySecret"
RAZORPAY_WEBHOOK_SECRET="placeholderWebhookSecret"

# Set to true to bypass external API calls and simulate payments locally
RAZORPAY_USE_MOCK="true"

# Cloudflare R2 (S3-Compatible Object Storage)
R2_USE_MOCK="true"
R2_ACCESS_KEY_ID="mock_access_key"
R2_SECRET_ACCESS_KEY="mock_secret_key"
R2_BUCKET_NAME="drivego-uploads"
R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://pub-placeholder.r2.dev"

